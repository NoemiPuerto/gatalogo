generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADOPTER
  SHELTER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum CatSex {
  FEMALE
  MALE
  UNKNOWN
}

enum AdoptionStatus {
  AVAILABLE
  PENDING
  ADOPTED
}

enum SwipeAction {
  LIKE
  DISLIKE
}

enum AdoptionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatar       String?
  phone        String?
  bio          String?
  role         UserRole @default(ADOPTER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shelter          Shelter?
  swipes           SwipeInterest[]
  favorites        Favorite[]
  adoptionRequests AdoptionRequest[]
  notifications    Notification[]
}

model Shelter {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  description        String
  address            String
  city               String
  country            String
  verificationStatus VerificationStatus @default(PENDING)
  logo               String?
  contactPhone       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cats             Cat[]
  adoptionRequests AdoptionRequest[]
}

model Cat {
  id                     String         @id @default(cuid())
  shelterId              String
  name                   String
  ageMonths              Int
  sex                    CatSex         @default(UNKNOWN)
  breed                  String
  personality            String
  healthStatus           String
  vaccinated             Boolean        @default(false)
  sterilized             Boolean        @default(false)
  compatibleWithChildren Boolean        @default(false)
  compatibleWithCats     Boolean        @default(false)
  compatibleWithDogs     Boolean        @default(false)
  location               String
  description            String
  adoptionStatus         AdoptionStatus @default(AVAILABLE)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  shelter          Shelter           @relation(fields: [shelterId], references: [id], onDelete: Cascade)
  photos           CatPhoto[]
  swipes           SwipeInterest[]
  favorites        Favorite[]
  adoptionRequests AdoptionRequest[]
}

model CatPhoto {
  id    String @id @default(cuid())
  catId String
  url   String
  order Int    @default(0)

  cat Cat @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, order])
}

model SwipeInterest {
  id        String      @id @default(cuid())
  userId    String
  catId     String
  action    SwipeAction
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cat  Cat  @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@unique([userId, catId])
  @@index([catId, action])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  catId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cat  Cat  @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@unique([userId, catId])
}

model AdoptionRequest {
  id        String                @id @default(cuid())
  userId    String
  catId     String
  shelterId String
  message   String
  status    AdoptionRequestStatus @default(PENDING)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cat     Cat     @relation(fields: [catId], references: [id], onDelete: Cascade)
  shelter Shelter @relation(fields: [shelterId], references: [id], onDelete: Cascade)

  @@unique([userId, catId])
  @@index([shelterId, status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
